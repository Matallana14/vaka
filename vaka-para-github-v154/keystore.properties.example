# =============================================================
# PLANTILLA — keystore.properties.example
# =============================================================
# Este archivo es SOLO una plantilla. NO contiene contraseñas reales.
#
# Para compilar Vaka con tu propia firma:
#   1. Copia este archivo y renómbralo a "keystore.properties"
#   2. Reemplaza los valores de abajo con los tuyos
#   3. NO subas "keystore.properties" a Git (ya está en .gitignore)
#
# Si todavía no tienes un keystore, genera uno con:
#   keytool -genkey -v -keystore key-store-vaka.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 -alias vaka
# =============================================================

# Ruta absoluta a tu archivo .jks
storeFile=C:/Users/tu_usuario/key-store-vaka.jks

# Contraseña del keystore (la que pusiste al crearlo)
storePassword=TU_PASSWORD_AQUI

# Alias del key dentro del keystore
keyAlias=vaka

# Contraseña del key (puede ser la misma que storePassword)
keyPassword=TU_KEY_PASSWORD_AQUI
